# Copy to .env and adjust. These map to the env vars used in application.yml.
DB_URL=jdbc:postgresql://localhost:5432/assemble_crm
DB_USERNAME=assemble
DB_PASSWORD=assemble
SERVER_PORT=8080

# Generate a strong Base64 secret (min 32 bytes) for production:
#   openssl rand -base64 48
APP_JWT_SECRET=Y2hhbmdlLW1lLXRoaXMtaXMtYS1kZXYtb25seS1zZWNyZXQtMzJieXRlcyE=
APP_JWT_ACCESS_EXP=900000
APP_JWT_REFRESH_EXP=604800000

APP_CORS_ORIGINS=http://localhost:4200
APP_SEED_ENABLED=true
